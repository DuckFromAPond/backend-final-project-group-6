<main class="min-h-screen flex flex-col items-center bg-gray-100 p-6">
    <div class="w-full max-w-4xl bg-white rounded-2xl shadow-lg p-6">

        <h1 class="text-2xl font-bold mb-6 text-center">{{itemHistories.id}}. {{item.name}} History</h1>

        <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
            <thead class="bg-blue-500 text-white">
                <tr>
                    <th class="px-4 py-2 text-left">Assignee</th>
                    <th class="px-4 py-2 text-left">Duration</th>
                    <th class="px-4 py-2 text-left">Reference Link</th>
                </tr>
            </thead>
            <tbody>
                {{#each itemHistories.histories}}
                <tr class="border-b hover:bg-gray-50">
                    <td class="px-4 py-2">{{this.assignee}}</td>
                    <td class="px-4 py-2">{{this.duration}}</td>
                    <td class="px-4 py-2">{{this.referenceLink}}</td>
                </tr>
                {{/each}}
            </tbody>
        </table>

    </div>
</main>