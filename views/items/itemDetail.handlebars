<main class="w-full flex flex-col justify-center items-center gap-y-5 p-6">
    {{!-- TOAST BANNER --}}
    <div class="fixed top-20 left-1/2 -translate-x-1/2 w-full max-w-md z-50">
        {{> toast}}
    </div>

    <div class="justify-self-center self-start">
        <h1 class="text-3xl font-bold text-gray-800">Item Detail</h1>
        <p class="text-gray-500 mt-1">Extensive details on the selected item</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <a href="/items" class="text-center text-white text-md bg-green-500 p-2 hover:bg-green-700 cursor-pointer rounded-md transition-all duration-300 ease-in-out">
            Back to Items
        </a>
        <a href="/items/{{id}}/history" class="text-center text-white text-md bg-green-500 p-2 hover:bg-green-700 cursor-pointer rounded-md transition-all duration-300 ease-in-out">
            View Item History
        </a>
    </div>

    <section class="w-full flex flex-col justify-center items-center gap-y-5">
        <section class="w-full max-w-5xl flex flex-col gap-6">

        <!-- IMAGE + BASIC INFO WRAPPER -->
            <div class="bg-white rounded-2xl shadow-lg p-6 flex flex-col lg:flex-row gap-8">

                <!-- IMAGE -->
                <div class="w-full lg:w-1/2 flex justify-center">
                <img src="{{this.imageUrl}}" alt="{{imageAlt}}"
                    class="w-full max-h-[400px] object-contain rounded-xl border"
                >
                </div>

                <!-- INFO -->
                <div class="w-full lg:w-1/2 flex flex-col gap-4">

                    <h2 class="text-6xl font-bold text-gray-800">{{name}}</h2>

                    <!-- STATUS BADGE -->
                    <div>
                        {{#ifContains status "Available"}}
                        <span class="px-3 py-1 text-sm rounded-full bg-green-100 text-green-700 font-semibold">
                            Available
                        </span>
                        {{/ifContains}}

                        {{#ifContains status "In-Use"}}
                        <span class="px-3 py-1 text-sm rounded-full bg-purple-100 text-purple-700 font-semibold">
                            In Use by <span class="underline">{{Owner}}</span>
                        </span>
                        {{/ifContains}}

                        {{#ifContains status "Maintenance"}}
                        <span class="px-3 py-1 text-sm rounded-full bg-orange-100 text-orange-700 font-semibold">
                            Maintenance
                        </span>
                        {{/ifContains}}

                        {{#ifContains status "Retired"}}
                        <span class="px-3 py-1 text-sm rounded-full bg-gray-200 text-gray-600 font-semibold">
                            Retired
                        </span>
                        {{/ifContains}}
                    </div>

                    <!-- QUICK DETAILS -->
                    <div class="grid grid-cols-2 gap-3 text-sm text-gray-700 mt-2">
                        <p><span class="font-semibold">ID:</span> {{id}}</p>
                        <p><span class="font-semibold">Category:</span> {{category}}</p>
                        <p><span class="font-semibold">Sub:</span> {{subCategory}}</p>
                        <p><span class="font-semibold">Model:</span> {{model}}</p>
                        <p><span class="font-semibold">Brand:</span> {{brand}}</p>
                        <p><span class="font-semibold">Serial:</span> {{serial}}</p>
                        <p class="col-span-2"><span class="font-semibold">Acquired:</span> {{dateAcquired}}</p>
                    </div>
                </div>
            </div>
            <!-- DESCRIPTION CARD -->
            <div class="bg-white rounded-2xl shadow p-6">
                <h3 class="text-lg font-semibold mb-2 text-gray-800">Description</h3>
                <p class="text-gray-600 leading-relaxed">{{description}}</p>
            </div>
        </section>
    </section>

        <div class="w-1/2 flex flex-col sm:flex-row justify-between gap-5">
            <button 
                class="hidden rounded-lg w-full p-2 cursor-pointer text-md bg-purple-500 hover:bg-purple-700 text-white transition-all duration-300 ease-in-out"
                onclick="toggleEdit(false)"
                id="hideEditBtn"
            >
                Hide Edit
            </button>

            <button 
                class="rounded-lg w-full p-2 cursor-pointer text-md bg-purple-500 hover:bg-purple-700 text-white transition-all duration-300 ease-in-out"
                onclick="toggleEdit(true)"
                id="showEditBtn"
            >
                Show Edit
            </button>
            {{!-- diabolical condition checking... --}}
            {{#if (eq user.role "Admin")}}
            {{#unless isRetired}}
                <button class="hidden rounded-lg w-full p-2 cursor-pointer text-md bg-red-500 hover:bg-red-700 text-white transition-all duration-300 ease-in-out"
                    onClick="toggleDelete(false)"
                    id="confirmRetireBtn"
                >
                    Confirm Retirement
                </button>

                <button class="rounded-lg w-full p-2 cursor-pointer text-md bg-red-500 hover:bg-red-700 text-white transition-all duration-300 ease-in-out"
                    onclick="toggleDelete(true)"
                    id="retireBtn"
                >
                    Retire
                </button>
            {{/unless}}
            {{/if}}
        </div>
    </section>
    
    <section id="editForm" class="hidden">
        {{> itemForm}}
    </section>
</main>

<script>
    const confirmRetireBtn = document.getElementById('confirmRetireBtn');
    const itemId = "{{id}}";

    function toggleEdit(show) {
        const editForm = document.getElementById('editForm');
        const showEditBtn = document.getElementById('showEditBtn');
        const hideEditBtn = document.getElementById('hideEditBtn');

        if(show) {
            editForm.classList.remove('hidden');
            hideEditBtn.classList.remove('hidden');
            showEditBtn.classList.add('hidden');
            editForm.scrollIntoView();
        }
        else {
            editForm.classList.add('hidden');
            hideEditBtn.classList.add('hidden');
            showEditBtn.classList.remove('hidden');
        }
    }

    function toggleDelete(show) {
        const retireBtn = document.getElementById('retireBtn');

        if(show) {
            retireBtn.classList.add('hidden');
            confirmRetireBtn.classList.remove('hidden');
        }
        else {
            retireBtn.classList.remove('hidden');
            confirmRetireBtn.classList.add('hidden');
        }
    }

    confirmRetireBtn.addEventListener('click', async (event) => {
        const response = await fetch(`/items/${itemId}`, {
            method: 'DELETE'
        });

        if (response.ok) {
            const data = await response.json();
            window.location.href = data.redirect;
        }
    });
</script>