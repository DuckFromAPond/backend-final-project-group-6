<div class="flex flex-col gap-6 p-6">
    {{!-- TOAST BANNER --}}
    <div class="fixed top-20 left-1/2 -translate-x-1/2 w-full max-w-md z-50">
        {{> toast}}
    </div>
    
    {{!-- Title --}}
    <h1 class="text-3xl font-bold">Items</h1>
    
    <section class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-10 w-full">
        <nav class="bg-white p-4 rounded-lg shadow-sm">
            <h2 class="text-lg font-semibold mb-2">Categories</h2>

            <ul class="space-y-1">
                {{#each categories}}
                <li>
                    <a href="/items?cat={{this.name}}"
                    class="block px-2 py-1 rounded hover:bg-gray-100 transition">
                    {{this.name}}
                    </a>
                </li>
                {{/each}}
            </ul>
        </nav>

        <form method="GET" action="/items"
            class="flex gap-2 justify-end items-center bg-white p-4 rounded-lg shadow-sm">

            <input
                type="text"
                name="q"
                id="q"
                placeholder="Search items..."
                class="w-full border border-gray-300 p-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400"
            >
            <button
                class="bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg transition">
                Search
            </button>
        </form>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-[45%_1fr] lg:grid-cols-[30%_1fr] gap-8 w-full">
        {{> itemForm}}
        
        {{!-- item grid --}}
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-10 w-full">
        {{#each items}}
            {{> itemCard}}
        {{/each}}
        </section>

    </section>

    <script>
        function openForm(id) {
            document.getElementById("modal").classList.remove("hidden");

            document.getElementById("file_item").value = id;
        }

        function closeForm() {
            document.getElementById("modal").classList.add("hidden");
        }
        
        function setDuration(hours) {
            document.getElementById("duration").value = hours;
        }
    </script>
</div>

