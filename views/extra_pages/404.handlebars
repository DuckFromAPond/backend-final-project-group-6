{{!--  FILE: views/404.handlebars --}}

<div style="min-height: 75vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f5f5f5;">
    <div style="max-width: 500px; margin: 0 auto; padding: 40px; border-radius: 8px; background: #fff; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">

    <h1 style="font-size: 72px; color: #e74c3c; margin: 0;">404</h1>
    <h2 style="color: #2c3e50; margin-top: 0;">Page Not Found</h2>

    {{!-- message --}}
    <p class="text-gray-500 mt-2 max-w-md">
      {{#if message}}
        {{message}}
      {{else}}
        The page you are looking for does not exist or has been moved.
      {{/if}}
    </p>

    <!-- Actions -->
    <div class="mt-6 flex gap-3">
      <a href="/"
        class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition">
        Go Home →
      </a>

      <a href="/items"
        class="px-4 py-2 border rounded text-gray-700 hover:bg-gray-300 transition">
        View Items
      </a>
    </div>

</section>