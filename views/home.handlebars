<div class="min-h-screen bg-gray-100 p-6">

  <!-- CARDS -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
    <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
      <h2 class="text-gray-500 font-semibold mb-2">Total Users</h2>
      <p class="text-2xl font-bold">{{dashboardData.totalUsers}}</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
      <h2 class="text-gray-500 font-semibold mb-2">Total Items</h2>
      <p class="text-2xl font-bold">{{dashboardData.totalItems}}</p>
    </div>

    <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
      <h2 class="text-gray-500 font-semibold mb-2">Pending Checkouts</h2>
      <p class="text-2xl font-bold">{{dashboardData.pendingCheckouts}}</p>
    </div>
  </div>

  <!-- RECENT TRANSACTIONS TABLE -->
  <div class="bg-white rounded-2xl shadow p-6 overflow-x-auto">
    <h2 class="text-xl font-bold mb-4">Recent Transactions</h2>
    <table class="min-w-full border border-gray-200 rounded-lg">
      <thead class="bg-blue-500 text-white">
        <tr>
          <th class="px-4 py-2 text-left">ID</th>
          <th class="px-4 py-2 text-left">User</th>
          <th class="px-4 py-2 text-left">Item</th>
          <th class="px-4 py-2 text-left">Type</th>
          <th class="px-4 py-2 text-left">Date</th>
        </tr>
      </thead>
      <tbody>
        {{#each dashboardData.recentTransactions}}
          <tr class="border-b hover:bg-gray-50">
            <td class="px-4 py-2">{{this.id}}</td>
            <td class="px-4 py-2">{{this.user}}</td>
            <td class="px-4 py-2">{{this.item}}</td>
            <td class="px-4 py-2">{{this.type}}</td>
            <td class="px-4 py-2">{{this.date}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>

</div>