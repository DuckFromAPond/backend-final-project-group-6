<main class="w-full flex flex-col justify-center items-center gap-y-5">
    <h1 class="text-3xl font-bold justify-self-center self-start">Item Detail</h1>

    <a href="/items" class="text-white text-md bg-green-500 p-2 hover:bg-green-700 cursor-pointer rounded-md transition-all duration-300 ease-in-out">
        Back to Items
    </a>

    <section class="w-full flex flex-col justify-center items-center gap-y-5">
        <img src="{{imagePath}}" alt="{{imageAlt}}"
            class="w-1/3 object-contain rounded-lg shadow-lg shadow-gray-500"
        >
        
        <h2 class="text-2xl font-semibold">{{name}}</h2>
        <p class="text-lg font-medium">{{description}}</p>
        <div class="w-1/2 flex justify-between gap-x-10">
            <button class="rounded-lg w-full p-2 cursor-pointer text-md bg-purple-500 hover:bg-purple-700 text-white transition-all duration-300 ease-in-out">Edit</button>
            <button class="rounded-lg w-full p-2 cursor-pointer text-md bg-red-500 hover:bg-red-700 text-white transition-all duration-300 ease-in-out">Delete</button>
        </div>
    </section>
</main>