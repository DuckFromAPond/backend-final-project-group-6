{{!-- REPORT PAGE --}}
{{!-- might be diff for admin and user but for now this is user focus or just use if to alternate --}}
<div class="p-6">

    {{!-- Header might not be needed  --}}
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-gray-800">Report page</h1>
        <p class="text-gray-500 mt-1">Detailed overview</p>
    </div>

    {{!-- Summary Cards --}}
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
        
        {{!-- Total Assets --}}
        <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
            <h2 class="text-gray-500 font-semibold mb-2">Total Assets</h2>
            <p class="text-2xl font-bold">{{totalItems}}</p>
        </div>

        {{!-- Recently Added Items --}}
        <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
            <h2 class="text-gray-500 font-semibold mb-2">Deployed Assets</h2>
            <p class="text-2xl font-bold">{{deployedItems}}</p>
        </div>

        {{!-- Recent Transactions --}}
        <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
            <h2 class="text-gray-500 font-semibold mb-2">Total users</h2>
            <p class="text-2xl font-bold">{{totalUsers}}</p>
        </div>

    </div>

    {{!-- Second section --}}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">

        {{!-- Asset age --}}
        <div class="bg-white p-6 rounded-2xl shadow col-span-2">
            <h2 class="text-lg font-semibold mb-4">Asset Aging (3+ Years)</h2>
            {{#if oldAssets.length}}
            <div class="overflow-x-auto">
            <table class="w-full text-left border border-gray-200">

            {{!-- table header --}}
            <thead class="bg-gray-800 text-white uppercase tracking-wider">
                <tr>
                    <th class="px-4 py-2">ID</th>
                    <th class="px-4 py-2">Name</th>
                    <th class="px-4 py-2">Serial number</th>
                    <th class="px-4 py-2">Category</th>
                    <th class="px-4 py-2">Sub Category</th>
                    <th class="px-4 py-2">Status</th>
                    <th class="px-4 py-2">Date Acquired</th>
                </tr>
            </thead>

            <tbody>
                {{#each oldAssets}}
                    <tr class="border-b hover:bg-gray-50 transition">

                        {{!-- ID --}}
                        <td class="px-4 py-2 font-mono text-xs font-semibold">
                            {{this.id}}
                        </td>

                        {{!-- NAME --}}
                        <td class="px-4 py-2">
                            <a href="/items/{{this.id}}" class="font-medium text-blue-600 hover:underline">
                                {{this.name}}
                            </a>
                        </td>

                        {{!-- Serial --}}
                        <td class="px-4 py-2 text-gray-700">
                            {{this.serial}}
                        </td>

                        {{!-- Category --}}
                        <td class="px-4 py-2 text-gray-800">
                            {{#if this.category}}
                                {{this.category}}
                            {{else}}
                                <span class="text-gray-400">Not set</span>
                            {{/if}}
                        </td>


                        <!-- Sub -->
                        <td class="px-4 py-2 text-gray-800">
                            {{#if this.subCategory}}
                                {{this.subCategory}}
                            {{else}}
                                <span class="text-gray-400">Not set</span>
                            {{/if}}
                        </td>

                        <!-- Status -->
                        <td class="px-4 py-2">
                            {{#if (eq this.status "In-Use")}}
                                <span class="px-3 py-1 text-sm font-semibold rounded-full bg-purple-100 text-purple-800">
                                    Overdue
                                </span>
                            {{else if (eq this.status "Available")}}
                                <span class="px-3 py-1 text-sm font-semibold rounded-full bg-emerald-100 text-emerald-800">
                                    Active
                                </span>
                            {{else}}
                                <span class="px-3 py-1 text-sm rounded-full bg-orange-100 text-orange-800">
                                    Maintenance
                                </span>
                            {{/if}}
                        </td>

                        {{!--Date --}}
                        <td class="px-4 py-2 text-gray-800">
                            {{#if this.formatted}}
                                {{this.formatted}}
                            {{else}}
                                <span class="text-gray-400">No data</span>
                            {{/if}}
                        </td>

                    </tr>

                {{/each}}
            </tbody>
            </table>
            </div>
            {{else}}
                <p class="text-gray-500">No user audit data found.</p>
            {{/if}}
        </div>
        {{!-- Recent Charts / Logs --}}
        <div class="bg-white p-6 rounded-2xl shadow col-span-2">
            <h2 class="text-lg font-semibold mb-4">User Audit (Owned Items)</h2>
            <form method="GET" action="/report" class="relative w-full pb-4">

                <button type="button" id="dropdownBtn"
                    class="w-full border border-gray-300 p-2 rounded-lg text-left bg-white">
                    {{#if selectedUserName}}
                        {{selectedUserName}}
                    {{else}}
                        Select user
                    {{/if}}
                </button>

                <div id="dropdownList"
                    class="hidden absolute z-20 w-full max-h-60 overflow-y-auto bg-white border rounded-lg shadow">

                    {{#each users}}
                    <div
                        class="p-2 hover:bg-gray-100 cursor-pointer"
                        onclick="selectUser('{{this.id}}', '{{this.name}} ({{this.email}})')"
                    >
                        {{this.name}} ({{this.email}})
                    </div>
                    {{/each}}

                </div>

                <input type="hidden" name="userId" id="userIdInput">

            </form>

            {{#if userAudit.length}}
                <div class="w-full overflow-x-auto">
                <table class="w-full text-left border border-gray-200">

                {{!-- table header --}}
                <thead class="bg-blue-500 text-white tracking-wider">
                    <tr>
                        <th class="px-4 py-2">ID</th>
                        <th class="px-4 py-2">Item</th>
                        <th class="px-4 py-2">Date Received</th>
                        <th class="px-4 py-2">Borrow duration</th>
                        <th class="px-4 py-2">Return Date</th>
                        <th class="px-4 py-2">Status</th>
                        <th class="px-4 py-2">Action</th>
                    </tr>
                </thead>

                <tbody>
                {{#each userAudit}}

                    <tr class="border-b hover:bg-gray-50 transition">

                        {{!-- ID --}}
                        <td class="px-4 py-2 font-mono text-xs font-semibold">
                            {{this.id}}
                        </td>

                        {{!-- NAME --}}
                        <td class="px-4 py-2">
                            <a href="/items/{{this.id}}" class="font-medium text-blue-600 hover:underline">
                                {{this.name}}
                            </a>
                        </td>

                        {{!-- RECEIVED --}}
                        <td class="px-4 py-2 text-gray-800">
                            {{#if this.createdAt}}
                                {{this.createdAt}}
                            {{else}}
                                <span class="text-gray-400">No data</span>
                            {{/if}}
                        </td>

                        {{!-- DURATION --}}
                        <td class="px-4 py-2 text-gray-800">
                            {{#if this.duration}}
                                {{this.duration}}
                            {{else}}
                                <span class="text-gray-400">Not set</span>
                            {{/if}}
                        </td>


                        <!-- DUE -->
                        <td class="px-4 py-2 text-gray-800">
                            {{#if this.dueDate}}
                                {{this.dueDate}}
                            {{else}}
                                <span class="text-gray-400">Not set</span>
                            {{/if}}
                        </td>

                        <!-- Status -->
                        <td class="px-4 py-2">
                            {{#if (eq this.status "overdue")}}
                                <span class="px-3 py-1 text-sm font-semibold rounded-full bg-red-100 text-red-800">
                                    Overdue
                                </span>
                            {{else if (eq this.status "active")}}
                                <span class="px-3 py-1 text-sm font-semibold rounded-full bg-emerald-100 text-emerald-800">
                                    Active
                                </span>
                            {{else}}
                                <span class="px-3 py-1 text-sm rounded-full bg-gray-100 text-gray-800">
                                    Unknown
                                </span>
                            {{/if}}
                        </td>

                        {{!--Action --}}
                        <td class="px-4 py-2">
                            <a
                                href="/api/files/docs/{{this.referenceUrl}}"
                                target="_blank"
                                class="bg-blue-500 hover:bg-gray-600 text-white text-sm px-4 py-2 m-1 rounded-lg transition shadow-sm inline-block"
                                >
                                View doc ↗
                            </a>
                        </td>

                    </tr>

                {{/each}}
                </tbody>
                </table>
                </div>
            {{else}}
                <p class="text-gray-500">No user audit data found.</p>
            {{/if}}
        </div>

    </div>

</div>
<script>
    const btn = document.getElementById("dropdownBtn");
    const list = document.getElementById("dropdownList");
    const input = document.getElementById("userIdInput");
    const selected = "{{selectedUserName}}";
    if (selected) btn.innerText = selected;

    btn.addEventListener("click", () => {
    list.classList.toggle("hidden");
    });

    function selectUser(id, label) {
    input.value = id;
    btn.innerText = label;
    list.classList.add("hidden");

    // optional auto submit
    input.closest("form").submit();
    }

    // close when clicking outside
    document.addEventListener("click", (e) => {
    if (!btn.contains(e.target) && !list.contains(e.target)) {
        list.classList.add("hidden");
    }
    });
</script>