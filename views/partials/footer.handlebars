<footer class="bg-white shadow-md border-t border-gray-200 mt-auto">
    <div class="max-w mx-auto px-10 py-6">

        <div class="grid grid-cols-3 gap-5">

            {{!-- LEFT: branding + copyright --}}
            <div class="flex flex-col space-y-1">
                <h2 class="text-sm font-semibold text-gray-800">Inventory Management System</h2>
                <p class="text-xs text-gray-500">© {{currentYear}} All rights reserved.</p>
                <p class="text-xs text-gray-400">Built for AUPP · Academic Use Only</p>
            </div>

            {{!-- CENTER: nav links --}}
            <div class="flex flex-col space-y-1 text-center">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-1">Quick Links</p>
                <a href="/home" class="text-xs text-gray-500 hover:text-blue-500 transition">Home</a>
                <a href="/items" class="text-xs text-gray-500 hover:text-blue-500 transition">Items</a>
                <a href="/owned" class="text-xs text-gray-500 hover:text-blue-500 transition">Owned</a>
                <a href="/report" class="text-xs text-gray-500 hover:text-blue-500 transition">Report</a>
                {{#if (eq user.role "Admin")}}
                <a href="/users" class="text-xs text-gray-500 hover:text-blue-500 transition">Users</a>
                <a href="/keys" class="text-xs text-gray-500 hover:text-blue-500 transition">Keys</a>
                {{/if}}
            </div>

            {{!-- RIGHT: contact --}}
            <div class="flex flex-col space-y-1 text-right">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-1">Contact</p>
                <a href="mailto:2023277tang@aupp.edu.kh" class="text-xs text-gray-500 hover:text-blue-500 transition">
                    Tang Huyming
                </a>
                <p class="text-xs text-gray-400">American University of Phnom Penh</p>
                <p class="text-xs text-gray-400">Phnom Penh, Cambodia</p>
            </div>

        </div>

        {{!-- BOTTOM: divider + signed in as --}}
        <div class="border-t border-gray-100 mt-4 pt-4 flex justify-between items-center">
            <p class="text-xs text-gray-400">
                Signed in as <span class="font-medium text-gray-600">{{user.name}}</span>
                <span class="text-gray-300 mx-1">•</span>
                <span class="text-gray-400">{{#if user.role}}{{user.role}}{{else}}User{{/if}}</span>
            </p>
            <p class="text-xs text-gray-300">v1.0.0</p>
        </div>

    </div>
</footer>