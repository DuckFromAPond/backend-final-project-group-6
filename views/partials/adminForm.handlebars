{{!-- 
    check-in/check-out form for admin (could use form but having 2 sep form)
 --}}

<div class="bg-white rounded-xl shadow-sm p-6">
    {{!-- NOTE TO FUTURE SELF: ADD AN [X] at the top right to close the form --}}
    <div class="flex pb-5">
        <button class="ml-auto text-md text-black hover:bg-gray-200 cursor-pointer p-2 text-center transition-all ease-in-out duration-300 rounded-lg" onclick="closeadminForm()">X</button>
    </div>
    <!-- Header -->
    <div class="text-center mb-12">
        <h1 class="text-4xl text-gray-800 mb-2">
            <span class=" font-bold ">{{title}}</span> Form
        </h1>
    </div>
        {{!-- Form set up --}}
    <form action="/transactions/{{action}}" method="POST" enctype="multipart/form-data" class="space-y-4">
        {{!-- Item ID --}}
        <div>
            <label for="file_item_admin" class="block text-sm font-medium text-gray-700 mb-1">
                Item ID
            </label>
            <input
                type="text"
                id="file_item_admin"
                name="itemId"
                value="{{id}}"
                placeholder="Item ID"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent outline-none transition"
            />
        </div>
            <label for="userEmail" class="block text-sm font-medium text-gray-700 mb-1">
                User Email
            </label>
            <input
                type="email"
                id="userEmail"
                name="userEmail"
                value="{{id}}"
                placeholder="User Email"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent outline-none transition"
            />
        {{#unless (eq title "Check-in")}}
        <div class="mb-2">
            <label for="duration" class="block text-sm font-medium text-gray-700 mb-1">
                Duration (in hours)
            </label>
            <input
                type="text"
                id="adminduration"
                name="duration"
                placeholder="Duration in hours"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent outline-none transition"
            />
            <p class="mt-1 text-xs text-gray-500 leading-snug">
                No duration means the item stays checked out until returned
            </p>
        </div>
        <div class="flex gap-2 mt-2">
            <button type="button"
                onclick="setadminDuration(24)"
                class="px-3 cursor-pointer py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded">
                1 Day
            </button>

            <button type="button"
                onclick="setadminDuration(24 * 7)"
                class="px-3 cursor-pointer py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded">
                1 Week
            </button>

            <button type="button"
                onclick="setadminDuration(24 * 30)"
                class="px-3 cursor-pointer py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded">
                1 Month
            </button>

            <button type="button"
                onclick="setadminDuration(24 * 365)"
                class="px-3 cursor-pointer py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded">
                1 Year
            </button>

        </div>
        {{/unless}}
        {{!-- File upload --}}
        <div>
            <label for="document" class="block text-sm font-medium text-gray-700 mb-1">
                File upload
            </label>
            <div class="relative">
                <input
                    type="file"
                    id="document"
                    name="document"
                    accept=".pdf,.doc,.docx"
                    required
                    class="cursor-pointer w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent outline-none transition file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-gray-200 file:text-gray-700 hover:file:bg-gray-300 file:cursor-pointer"
                />
            </div>
            <p class="text-xs text-gray-500 mt-1">
                Allowed: PDF (preferred), DOC, DOCX {{#if (eq config.DB_PROVIDER "supabase")}}• Max size: 50MB {{/if}}
            </p>
        </div>

        <button
            type="submit"
            class="cursor-pointer w-full bg-gray-500 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 transform hover:scale-105"
        >
            Submit
        </button>
    </form>
</div>
