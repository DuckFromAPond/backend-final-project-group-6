<div class="bg-white rounded-xl shadow-sm p-6">
    <div class="flex pb-5">
        <button class="ml-auto text-md text-black hover:bg-gray-200 cursor-pointer p-2 text-center transition-all ease-in-out duration-300 rounded-lg" onclick="closeSubcategory()">X</button>
    </div>

    <!-- Header -->
    <div class="text-center mb-12">
        <h1 class="text-4xl text-gray-800 mb-2">
            <span class=" font-bold ">{{title}}</span>
        </h1>
    </div>

    {{#each categories}}
        <h1 class="text-lg text-gray-700 mb-1 font-bold">{{this.name}}</h1>

        <div class="grid grid-cols-4 gap-2 mb-3">
            {{#each this.subCategories}}
                <a href="/items?subcat={{this.name}}" class="block px-2 py-1 rounded hover:bg-gray-500 hover:text-white ease-in-out duration-300 transition">{{this.name}}</a>
            {{/each}}
        </div>
    {{/each}}
</div>

<script>
    const categoryModal = document.querySelector('#categoryModal');

    // grab the right subcategories based on user selected category
    if (categoryModal) {
        let categories = {{{json categories}}};
        const subCategoryModal = document.querySelector('#subCategoryModal');

        categories.forEach(cat => {
            const wrapper = document.createElement('div');

            const h1 = document.createElement('h1');
            h1.textContent = cat.name;
            h1.className = "text-lg text-gray-700 mb-2 font-bold";

            wrapper.appendChild(h1);

            cat.subCategories.forEach(sub => {
                const a = document.createElement('a');
                a.href = "/items?subcat=" + sub.name;
                a.textContent = sub.name;

                wrapper.appendChild(a);
            });

            categoryModal.appendChild(wrapper);
        });
    }
</script>