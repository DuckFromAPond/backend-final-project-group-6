<div class="w-full max-h-80 flex flex-col shadow-lg shadow-gray-500 rounded-lg overflow-hidden">
    <div class="overflow-hidden w-full h-50">
        <img src="{{this.imageUrl}}" alt="{{this.imageAlt}}" onclick="location.href='/items/{{this.id}}'"
            class="w-full object-contain hover:scale-110 transition-all duration-300 ease-in-out cursor-pointer"
        >
    </div>

    <div class="p-2">
        <h3 class="text-lg font-medium">{{this.name}}</h3>
        
        <p>{{this.location}}</p>
        <p>{{this.description}}</p>
    </div>

    <div>
        <button class="w-full text-md text-gray-500 hover:text-gray-700 cursor-pointer p-2 text-center transition-all ease-in-out duration-300"
        onclick="openForm({{this.id}})" >
            Check-out
        </button>
        <button class="w-full text-md text-gray-500 hover:text-gray-700 cursor-pointer p-2 text-center transition-all ease-in-out duration-300" 
            onclick="location.href='/items/{{this.id}}'"
        >
            View More
        </button>
    </div>
</div>

{{!-- HIDDEN FORM PAGE --}}
<div id="modal" class="fixed inset-0 bg-black/65 flex items-center justify-center hidden z-50" onclick="closeForm()">
    {{!-- make closeform only work for background --}}
    <div onclick="event.stopPropagation()">     
        {{> form title="Check-out" action="checkout"}}
    </div>
</div>