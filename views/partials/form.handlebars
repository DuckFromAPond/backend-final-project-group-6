{{!-- 
    check-in/check-out form 
 --}}

<div class="max-w-4xl mx-auto my-30">
    <!-- Header -->
    <div class="text-center mb-12">
        <h1 class="text-4xl text-gray-800 mb-2">
            <span class=" font-bold ">{{title}}</span> Form
        </h1>
    </div>

    {{!-- Form container for check in --}}
    <div class="form-container bg-white rounded-xl shadow-sm p-6">
        {{!-- Form set up --}}
        <form action="/api/transactions/checkin" method="POST" enctype="multipart/form-data" class="space-y-4">
            {{!-- Item ID --}}
            <div>
                <label for="file_item" class="block text-sm font-medium text-gray-700 mb-1">
                    Item ID
                </label>
                <input
                    type="text"
                    id="file_item"
                    name="item"
                    placeholder="Item ID"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent outline-none transition"
                />
            </div>

            {{!-- File upload --}}
            <div>
                <label for="doc" class="block text-sm font-medium text-gray-700 mb-1">
                    File upload
                </label>
                <div class="relative">
                    <input
                        type="file"
                        id="image"
                        name="image"
                        accept=".pdf,.doc"
                        required
                        class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-500 focus:border-transparent outline-none transition file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-gray-200 file:text-gray-700 hover:file:bg-gray-300"
                    />
                </div>
                <p class="text-xs text-gray-500 mt-1">
                    Allowed: PDF, DOC 
                </p>
            </div>

            <button
                type="submit"
                class="w-full bg-gray-500 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 transform hover:scale-105"
            >
                Submit
            </button>
        </form>
    </div>
</div>
