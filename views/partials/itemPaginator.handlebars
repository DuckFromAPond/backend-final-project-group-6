<div id="paginate"
    class="w-full flex flex-row justify-center items-center"
>
    {{#if prevPage}}
        <a href="/items?page={{prevPage}}" class="rounded-lg py-2 px-3 font-bold border border-gray-500 hover:bg-gray-200 {{active}}">Prev</a>
    {{/if}}

    {{#each totalPages}}
        <a href="/items?page={{this}}" class="rounded-lg py-2 px-3 font-bold border border-gray-500 hover:bg-gray-200 {{active}}">{{this}}</a>
    {{/each}}

    {{#if nextPage}}
        <a href="/items?page={{nextPage}}" class="rounded-lg py-2 px-3 font-bold border border-gray-500 hover:bg-gray-200 {{active}}">Next</a>
    {{/if}}
</div>